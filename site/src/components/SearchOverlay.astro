---
// Pagefind search, rendered as a command-palette-style overlay above the page content.
// The pagefind bundle is generated after `astro build` with: npx pagefind --site dist
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<div
  id="search-overlay"
  class="fixed inset-0 z-50 flex items-start justify-center bg-slate-900/60 backdrop-blur-sm p-4 pt-[10vh]"
  data-base={base}
  hidden
>
  <div
    id="search-panel"
    role="dialog"
    aria-modal="true"
    aria-label="Search"
    class="w-full max-w-2xl max-h-[75vh] flex flex-col bg-white dark:bg-slate-900 rounded-xl shadow-2xl border border-slate-200 dark:border-slate-700 overflow-hidden"
  >
    <div class="flex items-center justify-between px-4 py-2 border-b border-slate-100 dark:border-slate-800">
      <span class="text-xs font-medium tracking-wider uppercase text-slate-400 dark:text-slate-500">Search</span>
      <button
        id="search-close"
        type="button"
        aria-label="Close search"
        class="p-1.5 rounded-lg text-slate-500 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <div id="search-results" class="flex-1 overflow-y-auto px-4 py-3">
      <div id="search"></div>
    </div>
  </div>
</div>

<link rel="stylesheet" href={`${base}/pagefind/pagefind-ui.css`} />
<script is:inline>
  // is:inline: pagefind-ui.js doesn't exist yet when Vite processes this file (it's
  // generated by `pagefind` after the build), and a processed dynamic import() here
  // ends up shipping an unpatched `__VITE_PRELOAD__` token that throws at runtime.
  // Also, pagefind-ui.js is a plain global-attaching script, not an ES module, so it
  // must be loaded via a <script> tag rather than import().
  (function () {
    const overlay = document.getElementById('search-overlay');
    const panel = document.getElementById('search-panel');
    const closeBtn = document.getElementById('search-close');
    const resultsContainer = document.getElementById('search-results');
    const searchEl = document.getElementById('search');
    if (!overlay || !panel || !closeBtn || !resultsContainer || !searchEl) return;

    const base = overlay.dataset.base;
    let pagefindInitialized = false;
    let lastFocusedEl = null;

    function initPagefind() {
      const script = document.createElement('script');
      script.src = `${base}/pagefind/pagefind-ui.js`;
      script.onload = () => {
        new window.PagefindUI({
          element: '#search',
          showSubResults: true,
          highlightParam: 'highlight',
          baseUrl: base,
        });
      };
      document.head.appendChild(script);
    }

    // Auto-click Pagefind's "Load more" button as it scrolls into view, turning
    // the built-in pagination into infinite scroll without touching pagefind-ui.js.
    const loadMoreObserver = new MutationObserver(() => {
      const btn = resultsContainer.querySelector('.pagefind-ui__button');
      if (btn && !btn.dataset.infiniteObserved) {
        btn.dataset.infiniteObserved = 'true';
        const io = new IntersectionObserver((entries) => {
          if (entries[0].isIntersecting) btn.click();
        }, { root: resultsContainer, rootMargin: '200px' });
        io.observe(btn);
      }
    });
    loadMoreObserver.observe(resultsContainer, { childList: true, subtree: true });

    function openSearch() {
      lastFocusedEl = document.activeElement;
      overlay.hidden = false;
      document.body.style.overflow = 'hidden';
      if (!pagefindInitialized) {
        pagefindInitialized = true;
        initPagefind();
      }
      requestAnimationFrame(() => {
        searchEl.querySelector('input')?.focus();
      });
    }

    function closeSearch() {
      if (overlay.hidden) return;
      overlay.hidden = true;
      document.body.style.overflow = '';
      lastFocusedEl?.focus();
    }

    window.openSearch = openSearch;
    window.closeSearch = closeSearch;

    closeBtn.addEventListener('click', closeSearch);
    overlay.addEventListener('click', (e) => {
      if (e.target === overlay) closeSearch();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !overlay.hidden) {
        closeSearch();
      } else if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
        e.preventDefault();
        if (overlay.hidden) openSearch();
        else closeSearch();
      }
    });

    // Track search queries via PostHog
    searchEl.addEventListener('pagefind:search', (e) => {
      const query = e.detail?.query;
      if (query) {
        window.posthog?.capture('search_performed', { query });
      }
    });
  })();
</script>
