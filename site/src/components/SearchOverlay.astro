---
import { MONOCHROME_LOGO_SLUGS } from '../data/monochromeLogos';

// Pagefind search, rendered as a command-palette-style overlay above the page content.
// The pagefind bundle is generated after `astro build` with: npx pagefind --site dist
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Pagefind's result thumbnails are plain <img> tags rendered outside our component
// tree (by pagefind-ui.js at runtime), so they can't pick up ServiceLogo's
// `dark:invert` class. Monochrome logos are dark strokes/fills designed for a light
// background, so without this they're nearly invisible in the dark-mode overlay.
const monochromeLogoCss = Array.from(MONOCHROME_LOGO_SLUGS)
  .map((slug) => `.dark .pagefind-ui__result-image[src$="/${slug}.svg"] { filter: invert(1); }`)
  .join('\n');
---

<div
  id="search-overlay"
  class="fixed inset-0 z-50 flex items-start justify-center bg-slate-900/60 backdrop-blur-sm p-4 pt-[10vh]"
  data-base={base}
  hidden
>
  <div
    id="search-panel"
    role="dialog"
    aria-modal="true"
    aria-label="Search"
    class="w-full max-w-2xl max-h-[75vh] flex flex-col bg-white dark:bg-slate-900 rounded-xl shadow-2xl border border-slate-200 dark:border-slate-700 overflow-hidden"
  >
    <div class="flex items-center justify-between px-4 py-2 border-b border-slate-100 dark:border-slate-800">
      <span class="text-xs font-medium tracking-wider uppercase text-slate-400 dark:text-slate-500">Search</span>
      <button
        id="search-close"
        type="button"
        aria-label="Close search"
        class="p-1.5 rounded-lg text-slate-500 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <div id="search-results" class="flex-1 overflow-y-auto px-4 py-3">
      <div id="search"></div>
    </div>
  </div>
</div>

<link rel="stylesheet" href={`${base}/pagefind/pagefind-ui.css`} />
<script define:vars={{ monochromeLogoCss }}>
  const style = document.createElement('style');
  style.textContent = monochromeLogoCss;
  document.head.appendChild(style);
</script>
<script is:inline>
  // is:inline: pagefind-ui.js doesn't exist yet when Vite processes this file (it's
  // generated by `pagefind` after the build), and a processed dynamic import() here
  // ends up shipping an unpatched `__VITE_PRELOAD__` token that throws at runtime.
  // Also, pagefind-ui.js is a plain global-attaching script, not an ES module, so it
  // must be loaded via a <script> tag rather than import().
  (function () {
    const overlay = document.getElementById('search-overlay');
    const panel = document.getElementById('search-panel');
    const closeBtn = document.getElementById('search-close');
    const resultsContainer = document.getElementById('search-results');
    const searchEl = document.getElementById('search');
    if (!overlay || !panel || !closeBtn || !resultsContainer || !searchEl) return;

    const base = overlay.dataset.base;
    let pagefindInitialized = false;
    let lastFocusedEl = null;

    function initPagefind() {
      const script = document.createElement('script');
      script.src = `${base}/pagefind/pagefind-ui.js`;
      script.onload = () => {
        new window.PagefindUI({
          element: '#search',
          showSubResults: true,
          highlightParam: 'highlight',
          baseUrl: base,
        });
      };
      document.head.appendChild(script);
    }

    // Auto-click Pagefind's "Load more" button as it scrolls into view, turning
    // the built-in pagination into infinite scroll without touching pagefind-ui.js.
    // The `clicking` flag guards against re-triggering while a page is still
    // loading (e.g. layout shifting the button in/out of the root margin);
    // it is cleared whenever the results DOM changes again.
    const loadMoreObserver = new MutationObserver(() => {
      const btn = resultsContainer.querySelector('.pagefind-ui__button');
      if (!btn) return;
      btn.dataset.clicking = '';
      if (!btn.dataset.infiniteObserved) {
        btn.dataset.infiniteObserved = 'true';
        const io = new IntersectionObserver((entries) => {
          if (entries[0].isIntersecting && btn.dataset.clicking !== 'true') {
            btn.dataset.clicking = 'true';
            btn.click();
          }
        }, { root: resultsContainer, rootMargin: '200px' });
        io.observe(btn);
      }
    });
    loadMoreObserver.observe(resultsContainer, { childList: true, subtree: true });

    // Pagefind injects its <input> asynchronously once pagefind-ui.js loads, so on
    // the first open it doesn't exist yet; wait for it via MutationObserver instead
    // of assuming it's present after a single animation frame.
    function focusInputWhenReady() {
      const input = searchEl.querySelector('input');
      if (input) {
        input.focus();
        return;
      }
      const inputObserver = new MutationObserver(() => {
        const readyInput = searchEl.querySelector('input');
        if (readyInput) {
          inputObserver.disconnect();
          readyInput.focus();
        }
      });
      inputObserver.observe(searchEl, { childList: true, subtree: true });
    }

    function openSearch() {
      lastFocusedEl = document.activeElement;
      overlay.hidden = false;
      document.body.style.overflow = 'hidden';
      if (!pagefindInitialized) {
        pagefindInitialized = true;
        initPagefind();
      }
      focusInputWhenReady();
    }

    function closeSearch() {
      if (overlay.hidden) return;
      overlay.hidden = true;
      document.body.style.overflow = '';
      lastFocusedEl?.focus();
    }

    window.openSearch = openSearch;
    window.closeSearch = closeSearch;

    closeBtn.addEventListener('click', closeSearch);
    overlay.addEventListener('click', (e) => {
      if (e.target === overlay) closeSearch();
    });
    function getFocusable() {
      return Array.from(
        panel.querySelectorAll('a[href], button:not([disabled]), input:not([disabled]), [tabindex]:not([tabindex="-1"])')
      );
    }

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !overlay.hidden) {
        closeSearch();
        return;
      }

      if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
        // Skip when typing in an editable element outside our own panel, so this
        // shortcut doesn't clobber other text-entry shortcuts elsewhere on the page.
        const target = e.target;
        const isEditable = target instanceof HTMLElement
          && (target.tagName === 'INPUT' || target.tagName === 'TEXTAREA' || target.isContentEditable);
        if (isEditable && !panel.contains(target)) return;

        e.preventDefault();
        if (overlay.hidden) openSearch();
        else closeSearch();
        return;
      }

      if (e.key === 'Tab' && !overlay.hidden) {
        const focusable = getFocusable();
        if (focusable.length === 0) return;
        const first = focusable[0];
        const last = focusable[focusable.length - 1];
        if (e.shiftKey && document.activeElement === first) {
          e.preventDefault();
          last.focus();
        } else if (!e.shiftKey && document.activeElement === last) {
          e.preventDefault();
          first.focus();
        }
      }
    });

    // Track search queries via PostHog
    searchEl.addEventListener('pagefind:search', (e) => {
      const query = e.detail?.query;
      if (query) {
        window.posthog?.capture('search_performed', { query });
      }
    });
  })();
</script>
